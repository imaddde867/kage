# Kage — Environment Configuration
# Copy to .env and edit.

# LLM backend: mlx_vlm (Qwen3.5) | mlx (text-only models like Qwen2.5)
LLM_BACKEND=mlx_vlm

# MLX model repo (downloaded automatically from Hugging Face on first run)
# Qwen3.5 on MLX currently uses mlx_vlm in text-only mode.
MLX_MODEL=mlx-community/Qwen3.5-4B-MLX-4bit
MLX_MAX_TOKENS=150

# Wake word (openwakeword model name, no extension)
WAKE_WORD=hey jarvis
WAKE_WORD_MODEL=hey_jarvis
WAKE_WORD_THRESHOLD=0.5

# STT: apple (macOS native, hardware-accelerated) | whisper (local faster-whisper)
STT_BACKEND=apple
WHISPER_MODEL=base

# TTS: Kokoro-82M via mlx-audio (Apple Silicon / MLX)
# Voice presets include: af_heart, bf_emma, bm_george
KOKORO_MODEL=mlx-community/Kokoro-82M-bf16
KOKORO_VOICE=af_heart
KOKORO_SPEED=1.0
# en-us (American), en-gb (British), ja (Japanese), zh (Chinese)
KOKORO_LANG_CODE=en-us

# Memory
MEMORY_DIR=./data/memory

# User
USER_NAME=Imad
ASSISTANT_NAME=Kage

# Name pronunciation (keeps display spelling as ASSISTANT_NAME)
# Spoken form should sound like /kaɡe/ in English voices.
TTS_NAME_OVERRIDE_ENABLED=true
TTS_NAME_PRONUNCIATION=Kah-gay
STT_NAME_NORMALIZATION_ENABLED=true
# Comma-separated variants to normalize back to ASSISTANT_NAME
STT_NAME_VARIANTS=kage,cage,kaj,kaige,kahge,ka-geh

# Audio (defaults work for most mics)
# SAMPLE_RATE=16000
# SILENCE_THRESHOLD=500
# SILENCE_DURATION=1.5
# MAX_RECORD_SECONDS=30

# Turn-taking / barge-in
ALLOW_BARGE_IN=true
INTERRUPT_MIN_SCORE=0.55
INTERRUPT_HOLD_MS=220
INTERRUPT_DEBOUNCE_MS=500
POST_TTS_GUARD_MS=250
