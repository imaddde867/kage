# ─────────────────────────────────────────
#  Kage (影) — Environment Configuration
#  "Shadow" in Japanese.
#  Copy this file to .env and you're good.
# ─────────────────────────────────────────

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
# Reasoning mode: false = faster direct answers, true = slower deeper reasoning
OLLAMA_THINK=false

# Wake word (default/current supported model is "Hey Jarvis")
# No pre-trained "hey_kage" model exists yet; custom training can be added later.
WAKE_WORD=hey jarvis

# STT backend: apple (macOS native, fast, no model load) | whisper (local, offline)
STT_BACKEND=apple
# Whisper model size (used when STT_BACKEND=whisper): tiny, base, small, medium
WHISPER_MODEL=base

# TTS backend: avspeech (AVFoundation, gap-free streaming) | macos_say | kittentts
TTS_BACKEND=avspeech
# AVSpeech voice identifier — run: python main.py --list-voices
# Download Siri voices: System Settings → Accessibility → Spoken Content → System Voice → Customize
AVSPEECH_VOICE_ID=
AVSPEECH_RATE=0.52

# macOS say voice (used when TTS_BACKEND=macos_say) — list with: say -v '?'
MACOS_SAY_VOICE=Ava (Enhanced)

# KittenTTS settings (only used when TTS_BACKEND=kittentts)
# TTS_VOICE=Jasper
# KITTENTTS_PROFILE=nano

# Memory storage path
MEMORY_DIR=./data/memory

# Your name
USER_NAME=Imad
