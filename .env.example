# Kage — Environment Configuration
# Copy this file to .env and adjust values as needed.

# -------------------------------
# LLM backend
# -------------------------------
# Supported: mlx_vlm (Qwen3.5 on MLX-VLM) | mlx (MLX-LM text models)
LLM_BACKEND=mlx_vlm
# Active LLM model (switch this value to swap models):
#   - mlx-community/Qwen3.5-9B-MLX-4bit            (recommended backend: mlx_vlm)
#   - mlx-community/Qwen3.5-4B-MLX-4bit            (recommended backend: mlx_vlm)
#   - mlx-community/Qwen2.5-7B-Instruct-4bit       (recommended backend: mlx)
#   - mlx-community/Qwen2.5-14B-Instruct-MLX-4bit  (recommended backend: mlx)
MLX_MODEL=mlx-community/Qwen3.5-9B-MLX-4bit
# Optional draft model for speculative decoding in LLM_BACKEND=mlx mode.
MLX_DRAFT_MODEL=
MLX_MAX_TOKENS=250
TEMPERATURE=0.3

# -------------------------------
# Wake word
# -------------------------------
WAKE_WORD=hey jarvis
WAKE_WORD_MODEL=hey_jarvis
WAKE_WORD_THRESHOLD=0.5

# -------------------------------
# STT
# -------------------------------
# apple = macOS SpeechRecognition, whisper = local faster-whisper fallback
STT_BACKEND=apple
WHISPER_MODEL=base

# -------------------------------
# TTS (Kokoro via mlx-audio)
# -------------------------------
KOKORO_MODEL=mlx-community/Kokoro-82M-bf16
KOKORO_VOICE=af_heart
KOKORO_SPEED=1.0
KOKORO_LANG_CODE=en-us

# -------------------------------
# Memory
# -------------------------------
MEMORY_DIR=./data/memory
RECENT_TURNS=4

# -------------------------------
# Identity
# -------------------------------
USER_NAME=Imad
ASSISTANT_NAME=Kage

# Keep display name as ASSISTANT_NAME, but force spoken pronunciation.
TTS_NAME_OVERRIDE_ENABLED=true
TTS_NAME_PRONUNCIATION=Kah-gay
STT_NAME_NORMALIZATION_ENABLED=true
STT_NAME_VARIANTS=kage,cage,kaj,kaige,kahge,ka-geh

# -------------------------------
# Audio tuning
# -------------------------------
SAMPLE_RATE=16000
WAKE_WORD_CHUNK_SIZE=1280
RECORD_CHUNK_SIZE=1024
SILENCE_THRESHOLD=500
SILENCE_DURATION=1.5
MAX_RECORD_SECONDS=30

# -------------------------------
# Turn-taking / barge-in
# -------------------------------
ALLOW_BARGE_IN=true
INTERRUPT_MIN_SCORE=0.55
INTERRUPT_HOLD_MS=220
INTERRUPT_DEBOUNCE_MS=500
POST_TTS_GUARD_MS=250

# -------------------------------
# Text mode
# -------------------------------
TEXT_MODE_TTS_ENABLED=false

# -------------------------------
# Second brain
# -------------------------------
SECOND_BRAIN_ENABLED=true
ENTITY_RECALL_BUDGET=400
PROACTIVE_DEBOUNCE_SECONDS=60
EXTRACTION_ENABLED=true

# -------------------------------
# Agent (tool-using loop)
# -------------------------------
AGENT_ENABLED=true
AGENT_MAX_STEPS=8
AGENT_TEMPERATURE=0.0
AGENT_ENTITY_MODE=relevance_filtered
AGENT_HISTORY_CHAR_BUDGET=8000
AGENT_OBSERVATION_MAX_CHARS=1800

# -------------------------------
# Heartbeat (proactive reminders)
# -------------------------------
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_SECONDS=300

# Do-not-disturb quiet hours (24h clock). Handles overnight windows.
DND_START_HOUR=23
DND_END_HOUR=7

# -------------------------------
# Web fetch TLS behavior
# -------------------------------
WEB_FETCH_TLS_MODE=strict
# Comma-separated trusted domains where insecure fallback is allowed when
# WEB_FETCH_TLS_MODE=allow_insecure_fallback.
WEB_FETCH_INSECURE_FALLBACK_DOMAINS=
# Retry SSL errors once using certifi CA bundle before insecure fallback logic.
WEB_FETCH_TLS_RETRY_WITH_CERTIFI=true

# -------------------------------
# Calendar read reliability
# -------------------------------
CALENDAR_READ_TIMEOUT_SECONDS=10
CALENDAR_READ_RETRY_COUNT=1
CALENDAR_READ_RETRY_DELAY_SECONDS=0.4
