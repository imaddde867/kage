# ─────────────────────────────────────────
#  Kage (影) — Environment Configuration
#  "Shadow" in Japanese.
#  Copy this file to .env and you're good.
# ─────────────────────────────────────────

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
# qwen3 reasoning mode: false = faster direct answers, true = slower deeper reasoning
OLLAMA_THINK=false

# Wake word (default/current supported model is "Hey Jarvis")
# No pre-trained "hey_kage" model exists yet; custom training can be added later.
WAKE_WORD=hey jarvis

# Whisper model size: tiny, base, small, medium
WHISPER_MODEL=base

# TTS backend: kittentts | macos_say
TTS_BACKEND=kittentts

# TTS voice — KittenTTS voices:
# Female: Bella, Luna, Rosie, Kiki
# Male:   Jasper, Bruno, Hugo, Leo
TTS_VOICE=Jasper
# KittenTTS profile: nano (fast) | mini (80M, best quality)
KITTENTTS_PROFILE=nano
# Optional local KittenTTS .onnx path. Leave empty to use the library default model.
# KITTENTTS_MODEL=
# macOS say voice (used as fallback, or as primary when TTS_BACKEND=macos_say)
# List voices with: say -v '?'
# Neural options on newer macOS builds include:
# SAY_FALLBACK_VOICE="Eddy (English (US))"
# SAY_FALLBACK_VOICE="Flo (English (US))"
SAY_FALLBACK_VOICE=Daniel
# Optional alias for the same voice setting (takes precedence over SAY_FALLBACK_VOICE):
# MACOS_SAY_VOICE="Eddy (English (US))"

# Memory storage path
MEMORY_DIR=./data/memory

# Your name
USER_NAME=Imad
