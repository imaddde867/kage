# Kage — Environment Configuration
# Copy to .env and edit.

# LLM backend: ollama | mlx
# mlx runs directly on Apple Neural Engine + GPU (no daemon required)
# ollama uses Metal GPU via llama.cpp (requires `ollama serve`)
LLM_BACKEND=mlx

# Ollama (used when LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TIMEOUT_SECONDS=60

# MLX (used when LLM_BACKEND=mlx)
# Model is downloaded automatically from Hugging Face on first run
# NOTE: Qwen3.5-9B is vision-only on MLX — use Qwen2.5 for text inference
# Recommended (text-only, fast): mlx-community/Qwen2.5-7B-Instruct-4bit
# Larger:                         mlx-community/Qwen2.5-14B-Instruct-4bit
MLX_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
MLX_MAX_TOKENS=2048

# Wake word (openwakeword model name, no extension)
WAKE_WORD=hey jarvis
WAKE_WORD_MODEL=hey_jarvis
WAKE_WORD_THRESHOLD=0.5

# STT: apple (macOS native, hardware-accelerated) | whisper (local faster-whisper)
STT_BACKEND=apple
WHISPER_MODEL=base

# TTS: macOS say — list voices with: say -v '?'
# Download neural voices: System Settings → Accessibility → Spoken Content → System Voice → Customize
MACOS_SAY_VOICE=Ava (Enhanced)

# Memory
MEMORY_DIR=./data/memory

# User
USER_NAME=Imad

# Audio (defaults work for most mics)
# SAMPLE_RATE=16000
# SILENCE_THRESHOLD=500
# SILENCE_DURATION=1.5
# MAX_RECORD_SECONDS=30
